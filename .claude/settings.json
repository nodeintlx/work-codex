{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "mcp__google-workspace__gmail_users_messages_list",
      "mcp__google-workspace__gmail_users_messages_get",
      "mcp__google-workspace__gmail_users_messages_attachments_get",
      "mcp__google-workspace__gmail_users_threads_list",
      "mcp__google-workspace__gmail_users_threads_get",
      "mcp__google-workspace__gmail_users_labels_list",
      "mcp__google-workspace__gmail_users_settings_filters_list",
      "mcp__google-workspace__gmail_users_getProfile",
      "mcp__google-workspace__gmail_users_history_list",
      "mcp__google-workspace__calendar_events_list",
      "mcp__google-workspace__calendar_events_get",
      "mcp__google-workspace__calendar_calendarList_list",
      "mcp__google-workspace__calendar_calendarList_get",
      "mcp__google-workspace__calendar_freebusy_query",
      "mcp__google-workspace__drive_files_list",
      "mcp__google-workspace__drive_files_get",
      "mcp__google-workspace__drive_files_export",
      "mcp__google-workspace__drive_files_download",
      "mcp__google-workspace__drive_about_get",
      "mcp__google-workspace__drive_drives_list",
      "mcp__google-workspace__drive_changes_list",
      "mcp__google-workspace__docs_documents_get",
      "mcp__google-workspace__sheets_spreadsheets_get",
      "mcp__google-workspace__sheets_spreadsheets_values_get",
      "mcp__google-workspace__sheets_spreadsheets_values_batchGet",
      "mcp__filesystem__read_file",
      "mcp__filesystem__read_text_file",
      "mcp__filesystem__read_multiple_files",
      "mcp__filesystem__list_directory",
      "mcp__filesystem__list_directory_with_sizes",
      "mcp__filesystem__search_files",
      "mcp__filesystem__directory_tree",
      "mcp__filesystem__get_file_info",
      "mcp__memory__*",
      "mcp__brave-search__*",
      "mcp__tavily__*"
    ],
    "deny": [
      "mcp__google-workspace__gmail_users_messages_send",
      "mcp__google-workspace__gmail_users_messages_delete",
      "mcp__google-workspace__gmail_users_messages_batchDelete",
      "mcp__google-workspace__gmail_users_threads_delete",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(chmod 777:*)",
      "Bash(curl*|*sh:*)",
      "Bash(wget*|*sh:*)",
      "Read(**/.ssh/*)",
      "Read(**/.aws/*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials.json)",
      "Read(**/token.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Work/.claude/hooks/validate-outbound.sh"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__gmail_users_drafts_create",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Email draft creation requires approval\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__gmail_users_drafts_update",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Email draft update requires approval\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__gmail_users_drafts_send",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Sending email draft requires approval\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__gmail_users_messages_send",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Direct email sending is blocked — use drafts workflow\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__calendar_events_insert",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Calendar event creation requires approval\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__calendar_events_update",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Calendar event modification requires approval\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__calendar_events_delete",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Calendar event deletion requires approval\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__drive_permissions_create",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Drive sharing/permission change requires approval\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__drive_permissions_update",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Drive permission change requires approval\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__drive_permissions_delete",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Drive permission removal requires approval\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__drive_files_delete",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Drive file deletion requires approval\"}}'"
          }
        ]
      },
      {
        "matcher": "mcp__google-workspace__drive_files_update",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"ask\",\"permissionDecisionReason\":\"Drive file modification requires approval\"}}'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Work/.claude/hooks/audit-log.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "TZ": "America/Toronto"
  }
}
